 the Once UI documentation](https://once-ui.com/docs/icons) for more information."]}],"\n",["$","$L2b",null,{"marginBottom":"16","codes":[{"code":"const social = [\n  {\n    name: \"GitHub\",\n    icon: \"github\",\n    link: \"https://github.com/once-ui-system/nextjs-starter\",\n  },\n  {\n    name: \"Email\",\n    icon: \"email\",\n    link: \"mailto:lorant@once-ui.com\",\n  },\n];","language":"tsx","label":"src/app/resources/content.js"}]}],"\n","$L2c","\n","$L2d","\n","$L2e","\n","$L2f"]
